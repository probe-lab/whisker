# Network to use: mainnet or testnet (default: testnet).
# Controls walrus CLI context, Sui RPC URL, and public aggregator/publisher endpoints.
#WALRUS_NETWORK=testnet

# Absolute path to a directory containing sui.keystore for the funded wallet.
# See README for wallet creation instructions.
WALRUS_WALLET_DIR=/home/user/.wallet

# Private key for the same wallet (suiprivkey-prefixed bech32).
# Used by whisker to sign blob deletion transactions.
# Obtain with: go run misc/extractkey.go
WHISKER_SUI_SIGNER=suiprivkey1...

# Walrus daemon image override (default pinned in compose.yaml).
#WALRUS_IMAGE=mysten/walrus-service:mainnet-v1.48.1

# Location identifier written to probe results (e.g. aws-eu-west-1).
WHISKER_PROBE_LOCATION=local

# Tuning (defaults shown).
#WHISKER_CHECK_INTERVAL=5m
#WHISKER_PROBE_SIZE=1048576
#WHISKER_EVENT_TIMEOUT=10m
#WHISKER_POLL_INTERVAL=5s
#WHISKER_LOG_LEVEL=info
